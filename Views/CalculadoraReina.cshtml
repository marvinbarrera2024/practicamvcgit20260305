@{
}
@{
    ViewData["Title"] = "Calculadora";
}

<div style="max-width: 400px; margin: 50px auto; font-family: Arial, sans-serif; border: 1px solid #ddd; padding: 20px; border-radius: 10px; background: #fff; box-shadow: 0px 4px 10px rgba(0,0,0,0.1);">
    <h2 style="text-align: center;">🧮 Calculadora</h2>
    <hr />

    <form method="post">
        <div style="margin-bottom: 15px;">
            <label>Número 1:</label>
            <input type="number" step="any" name="n1" value="@ViewBag.N1" style="width: 100%; padding: 8px;" required />
        </div>

        <div style="margin-bottom: 15px;">
            <label>Operación:</label>
            <select name="operacion" style="width: 100%; padding: 8px;">
                <option value="suma">Suma (+)</option>
                <option value="resta">Resta (-)</option>
                <option value="multi">Multiplicación (*)</option>
                <option value="div">División (/)</option>
            </select>
        </div>

        <div style="margin-bottom: 15px;">
            <label>Número 2:</label>
            <input type="number" step="any" name="n2" value="@ViewBag.N2" style="width: 100%; padding: 8px;" required />
        </div>

        <button type="submit" style="width: 100%; padding: 10px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer;">
            Calcular
        </button>
    </form>

    @if (ViewBag.Resultado != null || ViewBag.Error != null)
    {
        <hr />
        @if (ViewBag.Error != null)
        {
            <div style="padding: 10px; background: #f8d7da; color: #721c24; border-radius: 5px; text-align: center;">
                @ViewBag.Error
            </div>
        }
        else
        {
            <div style="padding: 10px; background: #d4edda; color: #155724; border-radius: 5px; text-align: center; font-size: 1.2em;">
                <strong>Resultado:</strong> @ViewBag.Resultado
            </div>
        }
    }
</div>
